# Shared Brain Configuration

# --- Required ---
BRAIN_API_KEY=your-api-key-here
PORT=8084

# --- Qdrant (vector store — always required) ---
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=your-qdrant-key-here

# --- Embedding Provider ---
# Options: openai, ollama
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=your-openai-key-here
# For Ollama:
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=nomic-embed-text

# --- Structured Storage Backend ---
# Options: sqlite (default), postgres, baserow, none
STRUCTURED_STORE=sqlite
SQLITE_PATH=./data/brain.db
# For Postgres:
# POSTGRES_URL=postgresql://user:pass@localhost:5432/shared_brain
# For Baserow:
# BASEROW_URL=http://localhost:8082
# BASEROW_API_KEY=your-baserow-token-here
# BASEROW_EVENTS_TABLE_ID=
# BASEROW_FACTS_TABLE_ID=
# BASEROW_STATUS_TABLE_ID=

# --- Consolidation Engine ---
CONSOLIDATION_ENABLED=true
CONSOLIDATION_INTERVAL=0 */6 * * *
# LLM provider for consolidation: openai, anthropic, ollama
CONSOLIDATION_LLM=openai
CONSOLIDATION_MODEL=gpt-4o-mini
# For Anthropic:
# ANTHROPIC_API_KEY=your-anthropic-key-here
# CONSOLIDATION_MODEL=claude-sonnet-4-20250514

# --- Memory Decay ---
# Decay factor per day without access (0.98 = 2% decay/day). Only affects facts and statuses.
DECAY_FACTOR=0.98
