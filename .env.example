# Shared Brain Configuration

# --- Required ---
BRAIN_API_KEY=your-admin-api-key-here
PORT=8084
# HOST=0.0.0.0  # Default: 127.0.0.1 (localhost only). Set to 0.0.0.0 for LAN/Docker access.

# --- Per-Agent API Keys (optional, recommended) ---
# Each agent gets its own key. The key name maps to the agent identity:
# AGENT_KEY_<name> → agent authenticates as "<name>" (underscores become hyphens)
# When using an agent key, source_agent must match the authenticated identity.
# BRAIN_API_KEY remains as admin/fallback (no identity binding).
# Generate keys with: openssl rand -hex 32
# AGENT_KEY_claude_code=your-key-here
# AGENT_KEY_n8n=your-key-here
# AGENT_KEY_morpheus=your-key-here

# --- Rate Limiting ---
# RATE_LIMIT_WRITES=60   # Max write requests per minute per key (default: 60)
# RATE_LIMIT_READS=120   # Max read requests per minute per key (default: 120)

# --- Qdrant (vector store — always required) ---
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=your-qdrant-key-here

# --- Embedding Provider ---
# Options: openai, gemini, ollama
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=your-openai-key-here
# For Gemini:
# EMBEDDING_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-key-here
# GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview  # default
# GEMINI_EMBEDDING_DIMS=3072                          # default (also supports 1536, 768 via Matryoshka)
# For Ollama:
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=nomic-embed-text

# --- Structured Storage Backend ---
# Options: sqlite (default), postgres, baserow, none
STRUCTURED_STORE=sqlite
SQLITE_PATH=./data/brain.db
# For Postgres:
# POSTGRES_URL=postgresql://user:pass@localhost:5432/shared_brain
# For Baserow:
# BASEROW_URL=http://localhost:8082
# BASEROW_API_KEY=your-baserow-token-here
# BASEROW_EVENTS_TABLE_ID=
# BASEROW_FACTS_TABLE_ID=
# BASEROW_STATUS_TABLE_ID=

# --- Consolidation Engine ---
CONSOLIDATION_ENABLED=true
CONSOLIDATION_INTERVAL=0 */6 * * *
# LLM provider for consolidation: openai, anthropic, ollama
CONSOLIDATION_LLM=openai
CONSOLIDATION_MODEL=gpt-4o-mini
# For Anthropic:
# ANTHROPIC_API_KEY=your-anthropic-key-here
# CONSOLIDATION_MODEL=claude-sonnet-4-20250514

# --- Memory Decay ---
# Decay factor per day without access (0.98 = 2% decay/day). Only affects facts and statuses.
DECAY_FACTOR=0.98

# --- Event TTL ---
# EVENT_TTL_DAYS=30  # Auto-expire low-importance, never-accessed events after N days (default: 30)

# --- MCP Server Timeouts ---
# BRAIN_MCP_TIMEOUT=15000          # Default timeout for MCP→API calls in ms (default: 15000)
# BRAIN_MCP_CONSOLIDATION_TIMEOUT=120000  # Timeout for sync consolidation calls in ms (default: 120000)

# --- Webhook Notifications ---
# Comma-separated URLs to receive memory events (fire-and-forget, non-blocking)
# WEBHOOK_NOTIFY_URLS=http://n8n.local:5678/webhook/brain-event
